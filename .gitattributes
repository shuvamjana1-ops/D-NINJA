# Normalize line endings for the whole project
* text=auto eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Force LF for code
*.js   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env  text eol=lf

# Binary files — no conversions
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.mp4  binary
*.mp3  binary
*.woff binary
*.woff2 binary
*.ttf  binary
