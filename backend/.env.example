# ─────────────────────────────────────────────────
# D'NINJA Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to Git!
# ─────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Admin email address (receives order & inquiry alerts)
ADMIN_EMAIL=your_admin@gmail.com

# Admin API secret — used as Bearer token for protected GET/PATCH endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=replace_with_a_long_random_string

# Gmail SMTP (use an App Password, NOT your real Gmail password)
# How to get an App Password: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# CORS — comma-separated list of allowed frontend origins
# Local dev examples: http://localhost:5500,http://127.0.0.1:5500
# Production example: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Rate Limiting (milliseconds)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_ORDERS=10
RATE_LIMIT_MAX_INQUIRIES=20
